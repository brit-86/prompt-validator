# LLM provider config (example)
LLM_PROVIDER=openai   # or "azure_openai" / "mock"
LLM_MODEL=gpt-4.1-mini
OPENAI_API_KEY=your_key_here
# Service behavior
MAX_PROMPT_CHARS=8000
LOG_LEVEL=INFO
#TARGET_SYSTEM_CONTEXT="This model can execute code and send emails in our production environment. Main risks: data exfiltration, privilege escalation, mass phishing."