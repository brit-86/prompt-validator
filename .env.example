# LLM provider config (example)
LLM_PROVIDER=openai   # or "azure_openai" / "mock"
LLM_MODEL=gpt-4.1-mini
OPENAI_API_KEY=your_key_here

# Service behavior
MAX_PROMPT_CHARS=8000
LOG_LEVEL=INFO
# On timeout or other errors: true = return conservative block (200), false = return 503
FAIL_SAFE_MODE=true
